# WealthSimple to ActualBudget Configuration
# Copy this file to ~/.config/ws-actual/config.toml and customize

[actualServer]
url = "http://localhost:5006"
syncId = "your-sync-id-here"

# Browser settings are optional. By default, ws-actual uses Playwright's bundled Chromium.
# For Flatpak Chrome, use:
#
# [browser]
# executablePath = "/var/lib/flatpak/exports/bin/com.google.Chrome"
# userDataDir = "/home/you/.var/app/com.google.Chrome/config/google-chrome"
#
# [browser.launchOptions]
# chromiumSandbox = true

# Account mappings - WealthSimple patterns to ActualBudget account IDs
# wsPattern can be exact strings or regex patterns

[[accounts]]
wsPattern = "WealthSimple Cash"
actualAccountId = "uuid-from-actualbudget"

[[accounts]]
wsPattern = ".*TFSA.*"
actualAccountId = "uuid-from-actualbudget"

[[accounts]]
wsPattern = ".*RRSP.*"
actualAccountId = "uuid-from-actualbudget"

[[accounts]]
wsPattern = "Chequing( • Solo)?"
actualAccountId = "uuid-from-actualbudget"
